# Quest2Travel Backend Environment Variables
# Copy this file to .env and fill in your values

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=true

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=quest2travel

# ── Gemini AI (REQUIRED for AI chat responses) ────────────────────────────────
# Free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── RapidAPI Key (ONE key for all 3 travel APIs below) ───────────────────────
# Get your key at: https://rapidapi.com/auth/sign-up → Dashboard → Default App → Key
# Then subscribe to both APIs (free plans available):
#   Flights + Hotels + Cars: https://rapidapi.com/DataCrawler/api/booking-com15
#   Trains:                  https://rapidapi.com/IRCTCAPI/api/irctc1
RAPIDAPI_KEY=your_rapidapi_key_here

# ── RapidAPI Hosts (do NOT change these) ─────────────────────────────────────
BOOKING_COM15_HOST=booking-com15.p.rapidapi.com
IRCTC_HOST=irctc1.p.rapidapi.com

# ── Geocoding (Nominatim is FREE — no key needed, leave as-is) ───────────────
GEOCODING_PROVIDER=nominatim
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# ── NOTE ─────────────────────────────────────────────────────────────────────
# If RAPIDAPI_KEY is empty, ALL travel searches automatically return
# realistic mock data labelled "Sample results". The app works fully
# without any API keys — just add GEMINI_API_KEY for real AI responses.
